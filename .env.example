DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=yunnansports
DATABASE_URL="mysql://root@localhost:3306/yunnansports"
NEXTAUTH_SECRET="change-me-for-production"
NEXTAUTH_URL="http://localhost:3000"

# --- Phase 2: vertical scale (optional, monolith) ---

# Redis — dashboard cache + BullMQ report queue
REDIS_URL="redis://127.0.0.1:6379"
CACHE_TTL_SECONDS=120
REPORT_QUEUE_ENABLED=true

# Object storage: local (default) or s3 (MinIO / AWS)
STORAGE_DRIVER=local
UPLOAD_DIR="./storage/uploads"

# MinIO (docker compose) — set STORAGE_DRIVER=s3 to enable
# S3_ENDPOINT="http://127.0.0.1:9000"
# S3_BUCKET="mis-uploads"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="minioadmin"
# S3_SECRET_KEY="minioadmin"
# S3_FORCE_PATH_STYLE=true

BACKUP_DIR="./storage/backups"

# --- Phase 3: multi-org / multi-project (monolith, no extra services) ---
# Active project: httpOnly cookie mis_project_id (set via POST /api/projects/select)
# See docs/architecture/phase-3.md before splitting Report/Notification microservices
