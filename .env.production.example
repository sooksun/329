# ====== .env.production (ตัวอย่าง) — คัดลอกเป็น .env.production แล้วกรอกค่า ======
# ใช้กับ: docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

NODE_ENV=production
PORT=3000

# ---------- ฐานข้อมูล: MariaDB ภายนอกที่มีอยู่แล้ว (192.168.1.4:3306) ----------
# Prisma provider เป็น mysql ซึ่งใช้กับ MariaDB ได้ (wire-compatible)
DB_HOST=192.168.1.4
DB_PORT=3306
DB_USER=CHANGE_ME_DB_USER       # ผู้ใช้ DB (กรอกเอง)
DB_PASS=CHANGE_ME_DB_PASSWORD   # รหัสผ่าน DB (กรอกเอง)
DB_NAME=yunnansports

# Prisma ใช้ค่านี้เป็นหลัก — ต้องตรงกับ DB_* ด้านบน
# ถ้าต่อจาก container ไม่ติดที่ 192.168.1.4 ให้ลองใช้ host.docker.internal:3306 แทน
DATABASE_URL="mysql://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@192.168.1.4:3306/yunnansports"

# ---------- NextAuth ----------
# สุ่มใหม่:  openssl rand -base64 32   หรือ
#           node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_32_BYTES
NEXTAUTH_URL=http://192.168.1.4:3000

# ---------- Redis (คิวรายงาน + cache) — รันใน compose นี้ ----------
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=120
REPORT_QUEUE_ENABLED=true

# ---------- Storage (เก็บไฟล์ในเครื่อง — map เป็น volume ./storage) ----------
STORAGE_DRIVER=local
UPLOAD_DIR=./storage/uploads
BACKUP_DIR=./storage/backups

# ---------- (ออปชัน) ใช้เฉพาะถ้าจะ seed ใหม่เท่านั้น — ⚠️ ลบข้อมูลเดิมทั้งหมด ----------
# ปกติ DB มีข้อมูลอยู่แล้ว ห้าม seed ซ้ำ ปล่อยว่างไว้
SEED_ADMIN_PASSWORD=
SEED_DIRECTOR_PASSWORD=
SEED_MEMBER_PASSWORD=
